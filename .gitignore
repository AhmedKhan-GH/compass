cmake-build-debug
.idea

# Ignore all third_party contents except submodule metadata
third_party/*
!third_party/.gitkeep

# Ignore build artifacts
*.lib
*.pdb
*.obj
*.o
*.a
*.dll
*.so
*.dylib

# Ignore downloaded/pre-built binaries
*-prebuilt/
/third_party/glew/auto/OpenGL-Registry/.dummy
/third_party/glew/auto/EGL-Registry/.dummy
